# File: .env.example
# Copy to .env.local and fill in your values

# ================================================
# SUPABASE CONFIGURATION
# ================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ================================================
# PAYTM PAYMENT GATEWAY
# Get credentials from: https://dashboard.paytm.com
# ================================================
VITE_PAYTM_MID=your_paytm_merchant_id
VITE_PAYTM_ENV=staging
# staging = test mode | production = live mode

# ================================================
# APP URL (for Paytm callback)
# ================================================
VITE_APP_URL=http://localhost:5173
# In production: https://edudoor.in

# ================================================
# SUPABASE EDGE FUNCTION SECRETS
# Set these in Supabase Dashboard → Settings → Secrets
# ================================================
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
PAYTM_MID=your_paytm_merchant_id
PAYTM_MERCHANT_KEY=your_paytm_merchant_key
PAYTM_WEBSITE=WEBSTAGING
# WEBSTAGING = test | DEFAULT = production
RESEND_API_KEY=your_resend_api_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1XXXXXXXXXX
ADMIN_USER_ID=your_admin_supabase_uuid
APP_URL=http://localhost:5173

# ================================================
# GOOGLE OAUTH (Supabase Auth Settings)
# Configure in Supabase Dashboard → Auth → Providers
# ================================================
# GOOGLE_CLIENT_ID=set_in_supabase_dashboard
# GOOGLE_CLIENT_SECRET=set_in_supabase_dashboard

# ================================================
# GOOGLE MAPS (Optional for address)
# ================================================
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key
